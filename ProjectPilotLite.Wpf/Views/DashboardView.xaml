<UserControl x:Class="ProjectPilotLite.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="20">
        <TextBlock Text="Tableau de bord" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
        <UniformGrid Columns="3" Rows="2">
            <StackPanel Margin="10"><TextBlock Text="Projets (total)" FontWeight="Bold"/><TextBlock Text="{Binding Stats.TotalProjets}" FontSize="24"/></StackPanel>
            <StackPanel Margin="10"><TextBlock Text="Projets en cours" FontWeight="Bold"/><TextBlock Text="{Binding Stats.ProjetsEnCours}" FontSize="24"/></StackPanel>
            <StackPanel Margin="10"><TextBlock Text="Projets bloqués" FontWeight="Bold"/><TextBlock Text="{Binding Stats.ProjetsBloques}" FontSize="24"/></StackPanel>
            <StackPanel Margin="10"><TextBlock Text="Tâches (total)" FontWeight="Bold"/><TextBlock Text="{Binding Stats.TotalTaches}" FontSize="24"/></StackPanel>
            <StackPanel Margin="10"><TextBlock Text="Tâches terminées" FontWeight="Bold"/><TextBlock Text="{Binding Stats.TachesTerminees}" FontSize="24"/></StackPanel>
            <StackPanel Margin="10"><TextBlock Text="Livrables déposés" FontWeight="Bold"/><TextBlock Text="{Binding Stats.LivrablesDeposes}" FontSize="24"/></StackPanel>
        </UniformGrid>
        <Button Content="Rafraîchir" Command="{Binding RafraichirCommand}" HorizontalAlignment="Left" Padding="10,4" Margin="0,16,0,0"/>
    </StackPanel>
</UserControl>